# Application Settings
APP_PORT=3000
APP_HOST=0.0.0.0
APP_DEBUG=false
APP_OS=Chrome
APP_BASIC_AUTH=user1:pass1,user2:pass2
APP_BASE_PATH=
APP_TRUSTED_PROXIES=0.0.0.0/0

# Database Settings
DB_URI="file:storages/whatsapp.db?_foreign_keys=on"
DB_KEYS_URI="file::memory:?cache=shared&_foreign_keys=on"

# WhatsApp Settings
WHATSAPP_AUTO_REPLY="Auto reply message"
WHATSAPP_AUTO_MARK_READ=false
WHATSAPP_AUTO_REJECT_CALL=false
WHATSAPP_AUTO_DOWNLOAD_MEDIA=true
WHATSAPP_WEBHOOK=https://webhook.site/07b69616-5943-4c7f-a8be-db4819df699e,https://webhook.site/09a38aff-d11a-4a38-a176-3f3efa0b5e8b
WHATSAPP_WEBHOOK_SECRET=super-secret-key
WHATSAPP_WEBHOOK_INSECURE_SKIP_VERIFY=false
WHATSAPP_WEBHOOK_EVENTS=message,message.reaction,message.revoked,message.edited,message.ack,message.deleted,group.participants
WHATSAPP_WEBHOOK_INCLUDE_OUTGOING=false
WHATSAPP_ACCOUNT_VALIDATION=true
WHATSAPP_PRESENCE_ON_CONNECT=unavailable
WHATSAPP_CHAT_STORAGE=true

# Chatwoot Integration
CHATWOOT_ENABLED=false
CHATWOOT_URL=https://app.chatwoot.com
CHATWOOT_API_TOKEN=xxxxxxxx
CHATWOOT_ACCOUNT_ID=111111
CHATWOOT_INBOX_ID=000000
CHATWOOT_DEVICE_ID=
CHATWOOT_IMPORT_MESSAGES=false
CHATWOOT_DAYS_LIMIT_IMPORT_MESSAGES=3

# Translation Feature (in-chat translation with 3 context-aware suggestions)
# When TRANSLATION_ENABLED=true, the UI exposes a globe icon on each message
# and a "Translate before send" toggle in the compose modal. Both call OpenAI
# with the recent chat context so the suggestions match the conversation tone.
TRANSLATION_ENABLED=false
TRANSLATION_PROVIDER=openai
TRANSLATION_OPENAI_API_KEY=
TRANSLATION_OPENAI_MODEL=gpt-4o-mini
TRANSLATION_OPENAI_BASE_URL=
TRANSLATION_DEFAULT_TARGET_LANG=en
TRANSLATION_CONTEXT_WINDOW=20
TRANSLATION_CACHE_ENABLED=true
TRANSLATION_TIMEOUT_SECONDS=30

# Translation RAG (Phase 3) — semantic retrieval over per-chat history and
# the user's own outbound messages. Reuses TRANSLATION_OPENAI_API_KEY for
# embeddings. Adds one extra ~tiny embeddings call per translate request and
# lazily indexes chats in the background. Off by default.
TRANSLATION_RAG_ENABLED=false
TRANSLATION_EMBEDDING_MODEL=text-embedding-3-small
TRANSLATION_RAG_PER_CHAT_POOL=200
TRANSLATION_RAG_STYLE_POOL=500
TRANSLATION_RAG_PER_CHAT_K=8
TRANSLATION_RAG_STYLE_K=4
TRANSLATION_RAG_BACKFILL_LIMIT=100
TRANSLATION_RAG_BACKFILL_BATCH=32
